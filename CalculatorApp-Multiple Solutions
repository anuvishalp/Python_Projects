                df[params["out_col"]] = df[params["price_col"]] * df[params["qty_col"]]

            elif name == "filter":
                col = params["column"]
                val = params["value"]
                op  = params["op"]

                if op == ">":
                    df = df[df[col] > val]
                elif op == ">=":
                    df = df[df[col] >= val]
                elif op == "<":
                    df = df[df[col] < val]
                elif op == "==":
                    df = df[df[col] == val]

        except Exception as e:
            logger.error(f"Transform '{name}' failed: {e}")
            raise

    return df
