import turtle
import time

class Snake:
    def __init__(self):
        self.segments = []
        self.create_snake()

    def create_snake(self):
        for _ in range(3):
            seg = turtle.Turtle("square")
            seg.color("white")
            seg.penup()
            self.segments.append(seg)

    def move(self):
        for i in range(len(self.segments)-1, 0, -1):
            self.segments[i].goto(self.segments[i-1].pos())
        self.segments[0].forward(20)

