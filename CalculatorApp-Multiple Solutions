python
def apply_steps(df, steps):
    for step in steps:
        name, params = next(iter(step.items()))
        if name == "add_total":
            df[params["out_col"]] = df[params["price_col"]] * df[params["qty_col"]]
        elif name == "filter":
            col = params["column"]
            val = params["value"]
            op  = params["op"]
            if op == ">":
                df = df[df[col] > val]
            elif op == ">=":
                df = df[df[col] >= val]
            elif op == "<":
                df = df[df[col] < val]
            elif op == "==":
                df = df[df[col] == val]
        # add more transforms as needed
    return df
