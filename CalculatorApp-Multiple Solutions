import pandas as pd
from etl.transform import apply_steps

def test_add_total():
    df = pd.DataFrame({"price": [10], "qty": [2]})
    steps = [{"add_total": {"price_col": "price", "qty_col": "qty", "out_col": "total"}}]

    result = apply_steps(df, steps)
    assert result["total"].iloc[0] == 20

def test_filter():
    df = pd.DataFrame({"total": [50, 200]})
    steps = [{"filter": {"column": "total", "op": ">", "value": 100}}]

    result = apply_steps(df, steps)
    assert len(result) == 1
    assert result["total"].iloc[0] == 200
