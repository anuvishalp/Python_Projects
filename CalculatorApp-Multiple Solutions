DECLARE
  upper_chars VARCHAR2(50) := 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  lower_chars VARCHAR2(50) := 'abcdefghijklmnopqrstuvwxyz';
  digits      VARCHAR2(20) := '0123456789';
  symbols     VARCHAR2(20) := '!@#$%^&*';
  pwd VARCHAR2(200);
BEGIN
  pwd :=
    SUBSTR(upper_chars, TRUNC(DBMS_RANDOM.VALUE(1, LENGTH(upper_chars))), 1) ||
    SUBSTR(lower_chars, TRUNC(DBMS_RANDOM.VALUE(1, LENGTH(lower_chars))), 1) ||
    SUBSTR(digits,      TRUNC(DBMS_RANDOM.VALUE(1, LENGTH(digits))), 1) ||
    SUBSTR(symbols,     TRUNC(DBMS_RANDOM.VALUE(1, LENGTH(symbols))), 1);

  DBMS_OUTPUT.PUT_LINE('Strong Password: ' || pwd);
END;
/
