from bs4 import BeautifulSoup

def parse_page(html, selectors):
    soup = BeautifulSoup(html, "html.parser")
    items = []
    for node in soup.select(selectors["item"]):
        row = {}
        for field, css in selectors["fields"].items():
            el = node.select_one(css)
            row[field] = el.get_text(strip=True) if el else None
        items.append(row)
    return items
